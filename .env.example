# Server
PORT=3001

# Speech-to-text: "webspeech" | "whisper"
STT_PROVIDER=webspeech

# AI provider: "ollama" | "lmstudio" | "gemini" | "openai" | "anthropic" | "groq"
AI_PROVIDER=ollama

# Cloud API keys
GEMINI_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GROQ_API_KEY=

# Local model servers
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

LMSTUDIO_BASE_URL=http://localhost:1234
# Replace with the identifier of the model loaded in LM Studio
LMSTUDIO_MODEL=local-model

# Text-to-speech
KOKORO_URL=http://localhost:8880
KOKORO_VOICE=af_heart

# Optional Whisper service
WHISPER_URL=http://localhost:9000

# Speaksy marketplace URL (frontend only)
VITE_MARKETPLACE_URL=https://speaksy.nuvo.page/marketplace/index.json
