---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Speaksy — AI English Practice</title>
  <meta name="description" content="Practice real English conversations with AI. Script mode, multi-provider AI, and freestyle practice." />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
</head>
<body>
  <!-- Hero -->
  <section class="hero">
    <div class="container">
      <h1 class="logo">Speaksy</h1>
      <p class="tagline">Practice real English conversations<br />with AI — on your own terms.</p>
      <div class="cta-row">
        <a class="btn-primary" href="https://hub.docker.com/r/nuvocode/speaksy" target="_blank" rel="noopener noreferrer">
          Pull from Docker Hub
        </a>
        <a class="btn-secondary" href="/marketplace">
          Browse Scripts →
        </a>
      </div>
    </div>
  </section>

  <!-- Features -->
  <section class="features">
    <div class="container">
      <div class="cards">
        <div class="card">
          <div class="card-icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
              <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
              <polyline points="14 2 14 8 20 8"/>
              <line x1="16" y1="13" x2="8" y2="13"/>
              <line x1="16" y1="17" x2="8" y2="17"/>
              <polyline points="10 9 9 9 8 9"/>
            </svg>
          </div>
          <h3>Script Mode</h3>
          <p>Follow structured dialogues covering real-world situations. Import community scripts or create your own.</p>
        </div>
        <div class="card">
          <div class="card-icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
              <polygon points="12 2 2 7 12 12 22 7 12 2"/>
              <polyline points="2 17 12 22 22 17"/>
              <polyline points="2 12 12 17 22 12"/>
            </svg>
          </div>
          <h3>Multi-Provider AI</h3>
          <p>Use OpenAI, Anthropic, Google Gemini, or Ollama locally. Bring your own API key — no lock-in.</p>
        </div>
        <div class="card">
          <div class="card-icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 1a3 3 0 0 0-3 3v8a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3z"/>
              <path d="M19 10v2a7 7 0 0 1-14 0v-2"/>
              <line x1="12" y1="19" x2="12" y2="23"/>
              <line x1="8" y1="23" x2="16" y2="23"/>
            </svg>
          </div>
          <h3>Freestyle Practice</h3>
          <p>Open-ended conversations on any topic. Built-in speech synthesis keeps practice hands-free.</p>
        </div>
        <div class="card">
          <div class="card-icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
              <path d="M3 18v-6a9 9 0 0 1 18 0v6"/>
              <path d="M21 19a2 2 0 0 1-2 2h-1a2 2 0 0 1-2-2v-3a2 2 0 0 1 2-2h3z"/>
              <path d="M3 19a2 2 0 0 0 2 2h1a2 2 0 0 0 2-2v-3a2 2 0 0 0-2-2H3z"/>
            </svg>
          </div>
          <h3>Real Voice, Real Ears</h3>
          <p>Kokoro TTS speaks back with natural, expressive audio. Whisper STT transcribes your voice accurately — no browser quirks.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Docker Quickstart -->
  <section class="quickstart">
    <div class="container">
      <h2>Get started in seconds</h2>
      <pre><code>docker pull nuvocode/speaksy
docker run -p 3000:3000 -p 5001:5001 nuvocode/speaksy</code></pre>
      <p class="hint">Then open <strong>http://localhost:3000</strong> in your browser.</p>
    </div>
  </section>

  <!-- Footer -->
  <footer>
    <div class="container">
      <span>MIT License</span>
      <span>·</span>
      <a href="https://github.com/nuvocode/speaksy" target="_blank" rel="noopener noreferrer">GitHub</a>
      <span>·</span>
      <a href="https://nuvocode.com" target="_blank" rel="noopener noreferrer">Nuvo Code</a>
    </div>
  </footer>
</body>
</html>

<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --bg: #09090b;
    --surface: #111113;
    --border: #27272a;
    --text: #fafafa;
    --muted: #a1a1aa;
    --purple: #a855f7;
    --purple-dim: rgba(168,85,247,.12);
    --font: 'Inter', system-ui, sans-serif;
    --mono: 'JetBrains Mono', monospace;
  }

  html { scroll-behavior: smooth; }

  body {
    font-family: var(--font);
    background: var(--bg);
    color: var(--text);
    line-height: 1.6;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }

  .container {
    max-width: 860px;
    margin: 0 auto;
    padding: 0 24px;
  }

  /* Hero */
  .hero {
    padding: 120px 0 80px;
    text-align: center;
  }

  .logo {
    font-size: clamp(3rem, 8vw, 5.5rem);
    font-weight: 700;
    letter-spacing: -0.04em;
    background: linear-gradient(135deg, #a855f7, #ec4899);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    line-height: 1.1;
    margin-bottom: 20px;
  }

  .tagline {
    font-size: clamp(1rem, 2.5vw, 1.25rem);
    color: var(--muted);
    margin-bottom: 40px;
    line-height: 1.7;
  }

  .cta-row {
    display: flex;
    gap: 12px;
    justify-content: center;
    flex-wrap: wrap;
  }

  .btn-primary {
    display: inline-flex;
    align-items: center;
    padding: 12px 24px;
    background: var(--purple);
    color: #fff;
    border-radius: 8px;
    text-decoration: none;
    font-weight: 600;
    font-size: 0.9rem;
    transition: opacity 150ms;
  }
  .btn-primary:hover { opacity: 0.85; }

  .btn-secondary {
    display: inline-flex;
    align-items: center;
    padding: 12px 24px;
    background: var(--purple-dim);
    color: var(--purple);
    border: 1px solid rgba(168,85,247,.3);
    border-radius: 8px;
    text-decoration: none;
    font-weight: 600;
    font-size: 0.9rem;
    transition: background-color 150ms;
  }
  .btn-secondary:hover { background: rgba(168,85,247,.2); }

  /* Features */
  .features {
    padding: 60px 0;
    border-top: 1px solid var(--border);
  }

  .cards {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 16px;
  }

  @media (max-width: 720px) {
    .cards { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 420px) {
    .cards { grid-template-columns: 1fr; }
  }

  .card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 28px 24px;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .card-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: 8px;
    background: var(--purple-dim);
    border: 1px solid rgba(168,85,247,.2);
    color: var(--purple);
    flex-shrink: 0;
  }

  .card h3 {
    font-size: 1rem;
    font-weight: 600;
    color: var(--text);
  }

  .card p {
    font-size: 0.875rem;
    color: var(--muted);
    line-height: 1.6;
  }

  /* Quickstart */
  .quickstart {
    padding: 60px 0;
    border-top: 1px solid var(--border);
    text-align: center;
  }

  .quickstart h2 {
    font-size: 1.5rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    margin-bottom: 24px;
  }

  pre {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 20px 24px;
    text-align: left;
    overflow-x: auto;
    margin-bottom: 16px;
  }

  code {
    font-family: var(--mono);
    font-size: 0.85rem;
    color: #d4d4d8;
    line-height: 1.8;
    white-space: pre;
  }

  .hint {
    font-size: 0.875rem;
    color: var(--muted);
  }

  /* Footer */
  footer {
    margin-top: auto;
    border-top: 1px solid var(--border);
    padding: 28px 0;
  }

  footer .container {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
    font-size: 0.8rem;
    color: var(--muted);
  }

  footer a {
    color: var(--muted);
    text-decoration: none;
    transition: color 150ms;
  }
  footer a:hover { color: var(--purple); }
</style>
