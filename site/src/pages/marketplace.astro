---
import scripts from '../../public/marketplace/index.json';
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Marketplace — Speaksy</title>
  <meta name="description" content="Browse and import conversation scripts for Speaksy." />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
</head>
<body>
  <header>
    <div class="container header-inner">
      <a href="/" class="back-link">← Speaksy</a>
      <h1>Script Marketplace</h1>
    </div>
  </header>

  <main class="container">
    <!-- Filters -->
    <div class="filters">
      <button class="filter-btn active" data-filter="all">All</button>
      <button class="filter-btn" data-filter="beginner">Beginner</button>
      <button class="filter-btn" data-filter="intermediate">Intermediate</button>
      <button class="filter-btn" data-filter="advanced">Advanced</button>
    </div>

    <!-- Script cards -->
    <div class="grid">
      {scripts.map((script) => (
        <article class="card" data-difficulty={script.difficulty}>
          <div class="card-header">
            <span class="title">{script.title}</span>
            <div class="meta">
              <span class={`badge badge-${script.difficulty}`}>{script.difficulty}</span>
              <span class="duration">~{script.estimatedMinutes}m</span>
            </div>
          </div>
          <p class="desc">{script.description}</p>
          {script.author && (
            <span class="author">by {script.author}</span>
          )}
          {script.tags && script.tags.length > 0 && (
            <div class="tags">
              {script.tags.map((tag) => (
                <span class="tag">{tag}</span>
              ))}
            </div>
          )}
          <div class="card-footer">
            <span class="line-count">{script.lines.length} lines</span>
          </div>
        </article>
      ))}
    </div>

    <!-- Contribute -->
    <section class="contribute">
      <h2>Want to contribute a script?</h2>
      <p>Open a pull request on GitHub and add your script to the marketplace JSON file.</p>
      <a href="https://github.com/nuvocode/speaksy/pulls" target="_blank" rel="noopener noreferrer" class="contribute-link">
        Submit a pull request →
      </a>
    </section>
  </main>

  <footer>
    <div class="container footer-inner">
      <span>MIT License</span>
      <span>·</span>
      <a href="https://github.com/nuvocode/speaksy" target="_blank" rel="noopener noreferrer">GitHub</a>
      <span>·</span>
      <a href="https://nuvocode.com" target="_blank" rel="noopener noreferrer">Nuvo Code</a>
    </div>
  </footer>

  <script>
    const buttons = document.querySelectorAll('.filter-btn');
    const cards = document.querySelectorAll('.card');

    buttons.forEach((btn) => {
      btn.addEventListener('click', () => {
        buttons.forEach((b) => b.classList.remove('active'));
        btn.classList.add('active');

        const filter = btn.dataset.filter;
        cards.forEach((card) => {
          if (filter === 'all' || card.dataset.difficulty === filter) {
            card.style.display = 'flex';
          } else {
            card.style.display = 'none';
          }
        });
      });
    });
  </script>
</body>
</html>

<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --bg: #09090b;
    --surface: #111113;
    --border: #27272a;
    --text: #fafafa;
    --muted: #a1a1aa;
    --purple: #a855f7;
    --purple-dim: rgba(168,85,247,.12);
    --green: #4ade80;
    --amber: #fbbf24;
    --red: #f87171;
    --font: 'Inter', system-ui, sans-serif;
    --mono: 'JetBrains Mono', monospace;
  }

  html { scroll-behavior: smooth; }

  body {
    font-family: var(--font);
    background: var(--bg);
    color: var(--text);
    line-height: 1.6;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }

  .container {
    max-width: 900px;
    margin: 0 auto;
    padding: 0 24px;
  }

  /* Header */
  header {
    border-bottom: 1px solid var(--border);
    padding: 20px 0;
  }

  .header-inner {
    display: flex;
    align-items: center;
    gap: 20px;
  }

  .back-link {
    font-size: 0.85rem;
    color: var(--muted);
    text-decoration: none;
    transition: color 150ms;
    flex-shrink: 0;
  }
  .back-link:hover { color: var(--purple); }

  header h1 {
    font-size: 1.1rem;
    font-weight: 600;
    letter-spacing: -0.01em;
  }

  /* Main */
  main {
    padding: 40px 24px;
    flex: 1;
  }

  /* Filters */
  .filters {
    display: flex;
    gap: 8px;
    margin-bottom: 28px;
    flex-wrap: wrap;
  }

  .filter-btn {
    font-family: var(--font);
    font-size: 0.8rem;
    font-weight: 500;
    padding: 6px 14px;
    border-radius: 6px;
    border: 1px solid var(--border);
    background: transparent;
    color: var(--muted);
    cursor: pointer;
    transition: all 150ms;
  }
  .filter-btn:hover { border-color: var(--purple); color: var(--purple); }
  .filter-btn.active {
    background: var(--purple-dim);
    border-color: rgba(168,85,247,.4);
    color: var(--purple);
  }

  /* Grid */
  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 16px;
    margin-bottom: 48px;
  }

  .card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 20px;
    display: flex;
    flex-direction: column;
    gap: 10px;
    transition: border-color 150ms;
  }
  .card:hover { border-color: rgba(168,85,247,.3); }

  .card-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 12px;
  }

  .title {
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--text);
    letter-spacing: -0.01em;
    line-height: 1.3;
  }

  .meta {
    display: flex;
    align-items: center;
    gap: 6px;
    flex-shrink: 0;
  }

  .badge {
    font-family: var(--mono);
    font-size: 0.65rem;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 2px 7px;
    border-radius: 5px;
    border: 1px solid;
  }

  .badge-beginner {
    color: var(--green);
    background: rgba(74,222,128,.12);
    border-color: rgba(74,222,128,.25);
  }
  .badge-intermediate {
    color: var(--amber);
    background: rgba(251,191,36,.12);
    border-color: rgba(251,191,36,.25);
  }
  .badge-advanced {
    color: var(--red);
    background: rgba(248,113,113,.12);
    border-color: rgba(248,113,113,.25);
  }

  .duration {
    font-family: var(--mono);
    font-size: 0.7rem;
    color: var(--muted);
  }

  .desc {
    font-size: 0.8rem;
    color: var(--muted);
    line-height: 1.6;
  }

  .author {
    font-family: var(--mono);
    font-size: 0.7rem;
    color: #71717a;
  }

  .tags {
    display: flex;
    gap: 5px;
    flex-wrap: wrap;
  }

  .tag {
    font-family: var(--mono);
    font-size: 0.65rem;
    color: #71717a;
    background: #18181b;
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 2px 6px;
    letter-spacing: 0.04em;
  }

  .card-footer {
    margin-top: auto;
    padding-top: 8px;
    border-top: 1px solid #1f1f22;
  }

  .line-count {
    font-family: var(--mono);
    font-size: 0.65rem;
    color: #52525b;
  }

  /* Contribute */
  .contribute {
    border: 1px dashed var(--border);
    border-radius: 10px;
    padding: 32px;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 10px;
  }

  .contribute h2 {
    font-size: 1rem;
    font-weight: 600;
  }

  .contribute p {
    font-size: 0.85rem;
    color: var(--muted);
  }

  .contribute-link {
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--purple);
    text-decoration: none;
    transition: opacity 150ms;
  }
  .contribute-link:hover { opacity: 0.8; }

  /* Footer */
  footer {
    border-top: 1px solid var(--border);
    padding: 24px 0;
  }

  .footer-inner {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
    font-size: 0.8rem;
    color: var(--muted);
  }

  footer a {
    color: var(--muted);
    text-decoration: none;
    transition: color 150ms;
  }
  footer a:hover { color: var(--purple); }
</style>
